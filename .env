# Redis Core Settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Queue Names
INBOUND_QUEUE=queue:marina_scrapes
OUTBOUND_SYNC_QUEUE=queue:vps_sync

# Local Compute & Storage (srv01)
OLLAMA_MODEL=qwen2.5:7b
LOCAL_DB_PATH=/opt/nexus-worker/nexus_storage.db

# Remote VPS Production Sync Target
VPS_IP=100.XXX.XX.XX
VPS_USER=root
VPS_DB_PATH=/path/to/your/vps_database.db
