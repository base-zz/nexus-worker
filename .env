# Redis Core Settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Queue Names
FUEL_INBOUND_QUEUE=queue:fuel_jobs
PRICING_INBOUND_QUEUE=queue:pricing_jobs
OUTBOUND_SYNC_QUEUE=queue:vps_sync

# Optional DLQ overrides (defaults to <queue>:dlq if not set)
# FUEL_DLQ=queue:fuel_jobs:dlq
# PRICING_DLQ=queue:pricing_jobs:dlq

# Ollama (local LLM)
# OLLAMA_HOST=http://localhost:11434

# Remote VPS Production Sync Target
VPS_IP=100.XXX.XX.XX
VPS_USER=root
VPS_DB_PATH=/path/to/your/vps_database.db
SSH_TIMEOUT=60
SYNC_MAX_BATCH=50
